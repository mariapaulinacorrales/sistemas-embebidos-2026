}

void tarea_sistema(void *param) {
    uint8_t uid[4];
    uint8_t uid_ant[4] = {0};
    int64_t t_ultima_lectura = 0;
    
    vTaskDelay(pdMS_TO_TICKS(500));
    lcd_clear();
    lcd_show("Panel bloqueado ", "Acerque credenc.");
    led_r(1); led_g(0); led_b(0);
    
    while (1) {
        // Leer hora del RTC
        uint8_t h, m, s;
        ds1307_get(&h, &m, &s);
        char hora[12];
        snprintf(hora, sizeof(hora), "%02d:%02d:%02d", h, m, s);
        
        // Actualizar LCD si está ACTIVO
        if (estado == ESTADO_ACTIVO) {
            lcd_cursor(0, 0); lcd_str(mensaje_lcd);
            lcd_cursor(1, 0); lcd_str(hora);
            for (int i = strlen(hora); i < 16; i++) lcd_str(" ");
        }
        
        uint8_t tagType[2];
        if (rc522_request(PICC_REQALL, tagType)) {
            uint8_t uid_temp[5];
            if (rc522_anticoll(uid_temp)) {
                memcpy(uid, uid_temp, 4);
                int64_t ahora_ms = esp_timer_get_time() / 1000;
                
                if (memcmp(uid, uid_ant, 4) != 0 || (ahora_ms - t_ultima_lectura) > 2000) {
                    memcpy(uid_ant, uid, 4);
                    t_ultima_lectura = ahora_ms;
                    
                    printf("UID leido: %02X:%02X:%02X:%02X\n", uid[0], uid[1], uid[2], uid[3]);
                    
                    if (uid_autorizado(uid)) {
                        if (estado == ESTADO_BLOQUEADO) {
                            lcd_clear();
                            lcd_show("Acceso concedido", hora);
                            led_r(0); led_g(1);
                            buzzer_corto();
                            vTaskDelay(pdMS_TO_TICKS(1000));
                            led_g(0);
                            estado = ESTADO_ACTIVO;
                            led_b(1);
                            strcpy(mensaje_lcd, "Sin mensajes    ");
                            lcd_clear();
                            lcd_show(mensaje_lcd, hora);
                        } else {
                            estado = ESTADO_BLOQUEADO;
                            led_b(0); led_r(1);
                            buzzer_corto();
                            lcd_clear();
                            lcd_show("Panel bloqueado ", "Acerque credenc.");
                        }
                    } else {
                        if (estado == ESTADO_BLOQUEADO) {
                            lcd_clear();
                            lcd_show("Acceso denegado ", "UID no registrad");
                            led_r_parpadear();
                            buzzer_largo();
                            vTaskDelay(pdMS_TO_TICKS(2000));
                            lcd_clear();
                            lcd_show("Panel bloqueado ", "Acerque credenc.");
                            led_r(1);
                        }
                    }
                    vTaskDelay(pdMS_TO_TICKS(500));
                }
            }
        }
        vTaskDelay(pdMS_TO_TICKS(200));
    }
}

void app_main(void) {
    
    // Configurar UART
    uart_config_t uart_cfg = {
        .baud_rate = 115200, .data_bits = UART_DATA_8_BITS,
        .parity = UART_PARITY_DISABLE, .stop_bits = UART_STOP_BITS_1,
        .flow_ctrl = UART_HW_FLOWCTRL_DISABLE, .source_clk = UART_SCLK_DEFAULT
    };
    uart_param_config(UART_NUM_0, &uart_cfg);
    uart_driver_install(UART_NUM_0, 256, 0, 0, NULL, 0);
    
    // NVS
    esp_err_t ret = nvs_flash_init();
    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND) {
        nvs_flash_erase();
        nvs_flash_init();
    }
    
    // LEDs
    gpio_config_t led_cfg = {
        .pin_bit_mask = (1ULL<<PIN_LED_ROJO)|(1ULL<<PIN_LED_VERDE)|(1ULL<<PIN_LED_AZUL),
        .mode = GPIO_MODE_OUTPUT, .pull_up_en = GPIO_PULLUP_DISABLE,
        .pull_down_en = GPIO_PULLDOWN_DISABLE, .intr_type = GPIO_INTR_DISABLE
    };
    gpio_config(&led_cfg);
    led_r(0); led_g(0); led_b(0);
    
    // Buzzer PWM
    ledc_timer_config_t bt = {
        .speed_mode = LEDC_LOW_SPEED_MODE, .timer_num = LEDC_TIMER_1,
        .duty_resolution = 10, .freq_hz = 2000, .clk_cfg = LEDC_AUTO_CLK
    };
    ledc_timer_config(&bt);
    ledc_channel_config_t bc = {
        .gpio_num = PIN_BUZZER, .speed_mode = LEDC_LOW_SPEED_MODE,
        .channel = LEDC_CHANNEL_1, .timer_sel = LEDC_TIMER_1, .duty = 0, .hpoint = 0
    };
    ledc_channel_config(&bc);
    
    // RC522 SPI
    gpio_config_t rst_cfg = {
        .pin_bit_mask = (1ULL << PIN_RST), .mode = GPIO_MODE_OUTPUT,
        .pull_up_en = GPIO_PULLUP_DISABLE, .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type = GPIO_INTR_DISABLE
    };
    gpio_config(&rst_cfg);
    gpio_set_level(PIN_RST, 1);
    
    spi_bus_config_t spi_bus = {
        .mosi_io_num = PIN_MOSI, .miso_io_num = PIN_MISO, .sclk_io_num = PIN_CLK,
        .quadhd_io_num = -1, .quadwp_io_num = -1
    };
    spi_bus_initialize(SPI2_HOST, &spi_bus, SPI_DMA_CH_AUTO);
    
    spi_device_interface_config_t rc522_dev = {
        .clock_speed_hz = 1000000, .mode = 0,
        .spics_io_num = PIN_CS, .queue_size = 7
    };
    spi_bus_add_device(SPI2_HOST, &rc522_dev, &rc522_spi);
    rc522_init();
    
    // I2C (LCD + RTC)
    i2c_config_t i2c_conf = {
        .mode = I2C_MODE_MASTER, .sda_io_num = I2C_SDA, .scl_io_num = I2C_SCL,
        .sda_pullup_en = GPIO_PULLUP_ENABLE, .scl_pullup_en = GPIO_PULLUP_ENABLE,
        .master.clk_speed = 50000
    };
    i2c_param_config(I2C_PORT, &i2c_conf);
    i2c_driver_install(I2C_PORT, I2C_MODE_MASTER, 0, 0, 0);
    
    lcd_init();
    
    ds1307_set_time(15, 45, 0); 
    
    // BLE
    nimble_port_init();
    ble_svc_gap_init();
    ble_svc_gatt_init();
    ble_svc_gap_device_name_set(DEVICE_NAME);
    ble_gatts_count_cfg(gatt_svcs);
    ble_gatts_add_svcs(gatt_svcs);
    ble_hs_cfg.sync_cb = ble_on_sync;
    nimble_port_freertos_init(ble_host_task);
    
    printf("\n=== PANEL HMI INDUSTRIAL ===\n");
    printf("BLE: %s\n", DEVICE_NAME);
    printf("UIDs autorizados:\n");
    for (int i = 0; i < NUM_UIDS; i++) {
        printf("  %02X:%02X:%02X:%02X\n", UIDS_AUTH[i][0], UIDS_AUTH[i][1], UIDS_AUTH[i][2], UIDS_AUTH[i][3]);
    }
    
    // Tarea principal en core 1
    xTaskCreatePinnedToCore(tarea_sistema, "sistema", 4096, NULL, 5, NULL, 1);
}

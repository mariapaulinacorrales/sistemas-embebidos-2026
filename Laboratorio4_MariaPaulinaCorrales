void ble_nus_send(const char *msg) {
    if (ble_conn_handle == BLE_HS_CONN_HANDLE_NONE || !ble_notify_enabled) return;
    struct os_mbuf *om = ble_hs_mbuf_from_flat(msg, strlen(msg));
    if (om) ble_gatts_notify_custom(ble_conn_handle, nus_tx_val_handle, om);
}

static int nus_rx_cb(uint16_t ch, uint16_t ah, struct ble_gatt_access_ctxt *ctxt, void *arg) {
    uint8_t data[17]; uint16_t len = 0;
    ble_hs_mbuf_to_flat(ctxt->om, data, 16, &len);
    data[len] = '\0';
    if (estado == ESTADO_ACTIVO) {
        strncpy(mensaje_lcd, (char *)data, 16);
        mensaje_lcd[16] = '\0';
        for (int i = strlen(mensaje_lcd); i < 16; i++) mensaje_lcd[i] = ' ';
        ble_nus_send("MSG OK\n");
    } else {
        ble_nus_send("PANEL BLOQUEADO\n");
    }
    return 0;
}


void led_r(int v) { gpio_set_level(PIN_LED_ROJO, v); }
void led_g(int v) { gpio_set_level(PIN_LED_VERDE, v); }
void led_b(int v) { gpio_set_level(PIN_LED_AZUL, v); }

void buzzer_on(int hz) {
    ledc_set_freq(LEDC_LOW_SPEED_MODE, LEDC_TIMER_1, hz);
    ledc_set_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1, 512);
    ledc_update_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1);
}
void buzzer_off(void) {
    ledc_set_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1, 0);
    ledc_update_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1);
}
void buzzer_corto(void) {
    buzzer_on(2000); vTaskDelay(pdMS_TO_TICKS(500)); buzzer_off();
}
void buzzer_largo(void) {
    buzzer_on(800); vTaskDelay(pdMS_TO_TICKS(2000)); buzzer_off();
}
void led_r_parpadear(void) {
    for (int i = 0; i < 3; i++) {
        led_r(0); vTaskDelay(pdMS_TO_TICKS(200));
        led_r(1); vTaskDelay(pdMS_TO_TICKS(200));
    }
}


static void ble_advertise(void);
static int ble_gap_cb(struct ble_gap_event *ev, void *arg) {
    switch (ev->type) {
        case BLE_GAP_EVENT_CONNECT:
            if (ev->connect.status == 0) ble_conn_handle = ev->connect.conn_handle;
            else ble_advertise();
            break;
        case BLE_GAP_EVENT_DISCONNECT:
            ble_conn_handle = BLE_HS_CONN_HANDLE_NONE;
            ble_notify_enabled = false;
            ble_advertise();
            break;
        case BLE_GAP_EVENT_SUBSCRIBE:
            if (ev->subscribe.attr_handle == nus_tx_val_handle)
                ble_notify_enabled = ev->subscribe.cur_notify;
            break;
        case BLE_GAP_EVENT_ADV_COMPLETE:
            ble_advertise();
            break;
        default: break;
    }
    return 0;
}

static void ble_advertise(void) {
    struct ble_hs_adv_fields f, r;
    struct ble_gap_adv_params p;
    memset(&f, 0, sizeof(f));
    f.flags = BLE_HS_ADV_F_DISC_GEN | BLE_HS_ADV_F_BREDR_UNSUP;
    f.uuids128 = (ble_uuid128_t *)&nus_svc_uuid;
    f.num_uuids128 = 1;
    f.uuids128_is_complete = 1;
    ble_gap_adv_set_fields(&f);
    
    memset(&r, 0, sizeof(r));
    const char *name = ble_svc_gap_device_name();
    r.name = (uint8_t *)name;
    r.name_len = strlen(name);
    r.name_is_complete = 1;
    ble_gap_adv_rsp_set_fields(&r);
    
    memset(&p, 0, sizeof(p));
    p.conn_mode = BLE_GAP_CONN_MODE_UND;
    p.disc_mode = BLE_GAP_DISC_MODE_GEN;
    ble_gap_adv_start(own_addr_type, NULL, BLE_HS_FOREVER, &p, ble_gap_cb, NULL);
}

static void ble_on_sync(void) {
    ble_hs_id_infer_auto(0, &own_addr_type);
    ble_advertise();
}
static void ble_host_task(void *param) {
